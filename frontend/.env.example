# Neemee Frontend Environment Variables
# Copy this to .env.local for local development with your actual values

# ==============================================
# SUPABASE CONFIGURATION (Required)
# ==============================================
# Get these values from your Supabase project dashboard at https://supabase.co/dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# ==============================================
# BACKEND SERVICE CONFIGURATION (Required)
# ==============================================
# URL of the FastAPI backend service for content extraction and processing
BACKEND_API_URL=http://localhost:8000
BACKEND_API_KEY=your-backend-api-key-here

# ==============================================
# APPLICATION CONFIGURATION (Required)
# ==============================================
# Base URL for the application - used for bookmarklet and magic link redirects
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Application environment
NODE_ENV=development

# ==============================================
# DEPLOYMENT INSTRUCTIONS
# ==============================================
# Local Development:
# 1. Copy this file: cp .env.example .env.local
# 2. Fill in your actual values in .env.local
# 3. Run: npm run dev
#
# Production Deployment:
# 1. Create .env.production with production values
# 2. Run: ./scripts/deploy.sh (automatically syncs secrets and deploys)
#
# Cloud Secrets (Production):
# - NEXT_PUBLIC_SUPABASE_URL ← neemee-supabase-url
# - NEXT_PUBLIC_SUPABASE_ANON_KEY ← neemee-supabase-anon-key  
# - BACKEND_API_URL ← neemee-backend-api-url
# - BACKEND_API_KEY ← neemee-backend-api-key