# Supabase Configuration (Required)
# Get these values from your Supabase project dashboard at https://supabase.co/dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# GitHub Repository Configuration (Optional - for file operations)
# Only required if using GitHub-based file storage
GITHUB_TOKEN=ghp_your_github_personal_access_token_here
GITHUB_REPO_OWNER=your-github-username
GITHUB_REPO_NAME=your-content-repository-name

# Backend Service Configuration (Required for content extraction)
# URL of the FastAPI backend service for content extraction
BACKEND_API_URL=http://localhost:8000
BACKEND_API_KEY=dev-key

# Application Configuration
NODE_ENV=development

# ================================
# CLOUD SECRETS INTEGRATION
# ================================
# In production, these environment variables are automatically populated from Google Cloud Secrets:
# - GITHUB_TOKEN ← neemee-github-token
# - NEXT_PUBLIC_SUPABASE_URL ← neemee-supabase-url
# - NEXT_PUBLIC_SUPABASE_ANON_KEY ← neemee-supabase-anon-key
# - GITHUB_REPO_OWNER ← neemee-github-repo-owner
# - GITHUB_REPO_NAME ← neemee-github-repo-name
# - BACKEND_API_URL ← neemee-backend-api-url
# - BACKEND_API_KEY ← neemee-backend-api-key
#
# To deploy with Cloud Secrets:
# 1. Run: ./scripts/setup-secrets.sh (one-time setup)
# 2. Run: ./scripts/deploy-with-secrets.sh (deploy with secrets)
#
# For local development, continue using this .env file with your actual values.