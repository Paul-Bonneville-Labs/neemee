# Prisma Database Configuration for Neemee Frontend
# Copy this to .env.local and update with your actual values

# Database Connection
# For local development with Cloud SQL Proxy:
# DATABASE_URL="postgresql://neemee_user:YOUR_PASSWORD@localhost:5432/neemee?schema=public"
# 
# For production Cloud Run (with Cloud SQL connection):
# DATABASE_URL="postgresql://neemee_user:YOUR_PASSWORD@localhost:5432/neemee?host=/cloudsql/PROJECT_ID:REGION:INSTANCE_NAME"
DATABASE_URL="postgresql://neemee_user:password@localhost:5432/neemee?schema=public"

# Cloud SQL Configuration (for reference)
# These are managed by Secret Manager in production
CLOUD_SQL_PROJECT_ID="your-project-id"
CLOUD_SQL_REGION="us-central1" 
CLOUD_SQL_INSTANCE_NAME="neemee-postgres-poc"
CLOUD_SQL_DATABASE_NAME="neemee"
CLOUD_SQL_USER="neemee_user"

# Development Settings
NODE_ENV="development"

# Prisma Configuration
PRISMA_CLI_QUERY_ENGINE_TYPE="binary"