{
  "name": "neemee-frontend",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "./scripts/dev-setup.sh && next dev --turbopack",
    "dev:lint": "./scripts/dev-setup.sh && concurrently \"next dev --turbopack\" \"npm run lint:watch\"",
    "dev:all": "./scripts/dev-setup.sh && concurrently --kill-others --names \"app,studio,lint,types\" -c \"cyan,green,yellow,blue\" \"next dev --turbopack\" \"dotenv -e .env.local -- prisma studio\" \"npm run lint:watch\" \"npm run type-check:watch\"",
    "dev:core": "./scripts/dev-setup.sh && concurrently --kill-others --names \"app,db\" -c \"cyan,magenta\" \"next dev --turbopack\" \"echo '✅ Database running at postgresql://neemee_user:local_dev_password@localhost:5433/neemee'\"",
    "dev:db": "./scripts/dev-setup.sh && concurrently --kill-others --names \"studio,db\" -c \"green,magenta\" \"dotenv -e .env.local -- prisma studio\" \"echo '✅ Database running - Connect at localhost:5433'\"",
    "dev:tools": "concurrently --kill-others --names \"lint,types\" -c \"yellow,blue\" \"npm run lint:watch\" \"npm run type-check:watch\"",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "lint:watch": "chokidar \"src/**/*.{ts,tsx,js,jsx}\" -c \"npm run lint\"",
    "type-check": "tsc --noEmit",
    "type-check:watch": "tsc --noEmit --watch",
    "check": "npm run type-check && npm run lint",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:ci": "jest --ci --coverage --watchAll=false",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:migrate:reset": "prisma migrate reset",
    "db:studio": "prisma studio",
    "db:local:start": "./scripts/db-start.sh",
    "db:local:stop": "./scripts/db-stop.sh",
    "db:local:reset": "./scripts/db-reset.sh",
    "dev:setup": "./scripts/dev-setup.sh",
    "dev:clean": "./scripts/dev-setup.sh && next dev --turbopack",
    "dev:tmux": "./scripts/tmux-dev.sh",
    "studio": "./scripts/dev-setup.sh && dotenv -e .env.local -- prisma studio"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.10.0",
    "@mdxeditor/editor": "^3.39.1",
    "@prisma/client": "^6.13.0",
    "@types/js-yaml": "^4.0.9",
    "@types/jsonwebtoken": "^9.0.10",
    "daisyui": "^5.0.50",
    "js-yaml": "^4.1.0",
    "lucide-react": "^0.525.0",
    "next": "15.3.5",
    "next-auth": "^5.0.0-beta.29",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@types/jest": "^29.5.14",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "chokidar-cli": "^3.0.0",
    "concurrently": "^9.2.0",
    "dotenv-cli": "^7.4.2",
    "eslint": "^9",
    "eslint-config-next": "15.3.5",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "prisma": "^6.13.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
