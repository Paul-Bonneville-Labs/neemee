# Neemee Monorepo .gitignore

# ========================================
# Operating System Files
# ========================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ========================================
# Frontend (Next.js/React/TypeScript)
# ========================================
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/build/
frontend/dist/
frontend/.env*.local
frontend/.vercel
frontend/*.log
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*
frontend/.pnpm-debug.log*

# ========================================
# Backend (Python/FastAPI)
# ========================================
backend/__pycache__/
backend/*.py[cod]
backend/*$py.class
backend/*.so
backend/.Python
backend/build/
backend/develop-eggs/
backend/dist/
backend/downloads/
backend/eggs/
backend/.eggs/
backend/lib/
backend/lib64/
backend/parts/
backend/sdist/
backend/var/
backend/wheels/
backend/share/python-wheels/
backend/*.egg-info/
backend/.installed.cfg
backend/*.egg
backend/MANIFEST

# Python virtual environments
backend/venv/
backend/env/
backend/ENV/
backend/env.bak/
backend/venv.bak/

# Python testing
backend/.pytest_cache/
backend/.coverage
backend/htmlcov/
backend/.tox/
backend/.nox/
backend/.coverage.*
backend/coverage.xml
backend/*.cover
backend/*.py,cover
backend/.hypothesis/

# ========================================
# Environment Variables
# ========================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env

# ========================================
# Database
# ========================================
*.db
*.sqlite
*.sqlite3

# ========================================
# Logs
# ========================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ========================================
# IDE and Editor Files
# ========================================
.vscode/
.idea/
*.swp
*.swo
*~

# ========================================
# Deployment
# ========================================
deployment/secrets/
deployment/*.key
deployment/*.pem

# ========================================
# Backup Files (keep docs_backup for now)
# ========================================
# docs_backup/

# ========================================
# Dependencies
# ========================================
node_modules/
*/node_modules/

# ========================================
# Build artifacts
# ========================================
*/build/
*/dist/
*/out/

# ========================================
# Git Worktrees
# ========================================
.worktrees/
backend/.worktrees/
frontend/.worktrees/

# ========================================
# Temporary files
# ========================================
tmp/
temp/
*.tmp
*.temp
